{
  "name": "smart-maintenance",
  "version": "2.0.0",
  "description": "API de devis garage avec qualimétrie",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/open-browser.js http://localhost:3000/ && node server.js",
    "dev": "node scripts/open-browser.js http://localhost:3000/ && nodemon server.js",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "sonar": "sonar-scanner"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sonar-scanner": "^3.1.0",
    "supertest": "^6.3.3",
    "vite": "^8.0.10"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/__tests__/**",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
