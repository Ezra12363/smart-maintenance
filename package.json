{
  "name": "smart-maintenance",
  "version": "2.0.0",
  "description": "API de devis garage avec qualimétrie",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "sonar": "sonar-scanner"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "sonar-scanner": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/__tests__/**",
      "!src/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": ["**/__tests__/**/*.test.js"]
  }
}
