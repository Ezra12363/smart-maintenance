{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "complexity": ["error", 5],
    "max-depth": ["error", 2],
    "max-nested-callbacks": ["error", 2],
    "max-statements": ["error", 20],
    "max-lines-per-function": ["warn", 30],
    "no-else-return": "error",
    "no-unused-vars": "error",
    "consistent-return": "error"
  }
}
